<% layout("/layouts/boilerplate") %>
    <div class="row mt-3">
        <div class="col-8 offset-3">
    <h3> Listing Details </h3>
</div>
    <div class="card col-6 offset-3 showCard " >
        <img src="<%= listing.image%>" class="card-img-top showimg mb-2" alt="listing_img">

        <div class="card-body">
            <p class="card-text">
            <b> <%= listing.title %>  </b> <br>
            <%= listing.description %> <br>
            &#8377;  <%= listing.price.toLocaleString("en-IN") %> <br>
            <%= listing.location %> <br>
             <%= listing.country %> <br>
        </p>
        </div>
    </div>

    <div class="btns">
        <a href="/listings/<%=listing.id%>/edit " class="btn btn-dark col-1 offset-3 editBtn mt-3"> Edit </a>
        
        <form method="post" action ="/listings/<%= listing._id%>?_method=DELETE">
        <button class="btn btn-dark offset-5 mt-3">
            Delete
        </button>
    </form>
    </div>
</div>

